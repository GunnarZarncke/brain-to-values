digraph paper_references {
    rankdir=BT;
    bgcolor="transparent";
    pad=0.4;
    nodesep=0.6;
    ranksep=0.8;

    node [
        shape=box, style="rounded,filled",
        fillcolor="#dce9f5", color="#4a7fb5",
        fontname="Helvetica", fontsize=10,
        margin="0.25,0.15", penwidth=1.5
    ];
    edge [fontname="Helvetica", fontsize=8, color="#555555"];

    // Foundational papers (bottom tier)
    FEL  [label="Stratification of\nFree-Energy Loops\n(Jul 2025)", fillcolor="#b8d4a8", color="#5a8a42"];
    CSR  [label="Consciousness as\nSelf-Referential Process\n(Sep 2025)", fillcolor="#f5e6b8", color="#b89a3e"];

    // Middle tier
    SRL  [label="Status Regulation\nLoops\n(Aug 2025)"];
    LHV  [label="Loop–Hub–Value\nModel (LHV)\n(Jul 2025)"];
    CAB  [label="Consciousness &\nAgency Backbone\n(Aug 2025)"];

    // Upper tier
    LHCV [label="Loop–Hub–Control–\nValue (LHCV)\n(May 2026)"];
    VBD  [label="Value Bundle\nDrift\n(May 2026)"];
    UoC  [label="Unit of Caring\n(May 2026)"];

    // Explicit citations (solid)
    LHV  -> FEL  [label="cites", penwidth=2, color="#2a6099"];
    LHCV -> FEL  [label="cites", penwidth=2, color="#2a6099"];
    UoC  -> CSR  [label="cites", penwidth=2, color="#2a6099"];

    // Conceptual / extends (dashed)
    LHCV -> LHV  [style=dashed, label="extends"];
    SRL  -> FEL  [style=dashed, label="applies\nframework"];
    VBD  -> LHCV [style=dashed, label="uses value\nconcepts"];
    UoC  -> LHCV [style=dashed, label="uses control\nframework"];
    CAB  -> CSR  [style=dashed, label="shared consciousness\nframework"];
}
